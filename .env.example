# Copy to .env for local dev, or set these as deploy secrets on unfazed.
# NEVER commit real values — .env is gitignored.

# --- Model (required) -------------------------------------------------------
# OpenRouter API key, used by agent/agent.ts (Claude Sonnet 4.6).
OPENROUTER_API_KEY=

# --- Telegram channel (required to run the bot) -----------------------------
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Optional but recommended: must equal the secret_token you pass to setWebhook;
# the channel rejects any inbound update without a matching header.
TELEGRAM_WEBHOOK_SECRET_TOKEN=
# Optional: your bot's @handle without the @, for group @mention/command detection.
TELEGRAM_BOT_USERNAME=

# --- unfazed MCP connection (required for the deploy tools) ------------------
# A self-registered agent token: POST https://unfazed.dev/agents/register
# {"agent_name":"my bot"} -> use the returned access_token here.
UNFAZED_MCP_TOKEN=

# --- eve durable-workflow local world (runtime config, NOT secret) ----------
# eve's durable workflow needs a writable state dir and the local base URL it
# serves on.
WORKFLOW_LOCAL_DATA_DIR=/tmp/.workflow-data
WORKFLOW_LOCAL_BASE_URL=http://127.0.0.1:3000
